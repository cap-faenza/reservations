# Copia questo file in .env.production sul server e personalizza i valori.

# Dominio servito da Caddy. Deve puntare al server via DNS prima del deploy.
SITE_DOMAIN="prenotazioni.example.com"

# URL pubblico usato per QR code e link email.
BASE_URL="https://prenotazioni.example.com"

# SQLite dentro il volume persistente /app/data del container.
DATABASE_URL="file:./data/production.db"

# Cambia sempre questi valori in produzione.
ADMIN_PIN="cambia-questo-pin"
AUTH_SECRET="genera-con-openssl-rand-hex-32"

# Nome mostrato nell'interfaccia.
NEXT_PUBLIC_SITE_NAME="CAP Faenza"

# SMTP per l'invio delle email.
# Se non configurato, il link di gestione viene solo loggato nei log del container.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="CAP Faenza <noreply@example.com>"
