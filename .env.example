# Copia questo file in .env e personalizza i valori

DATABASE_URL="file:./prisma/dev.db"

# PIN di accesso admin
ADMIN_PIN="2026"
# Segreto per la firma dei cookie di sessione (genera con: openssl rand -hex 32)
AUTH_SECRET="cambiami"
# URL pubblico del sito (usato per QR code e link nelle email). Se vuoto, viene dedotto dalla richiesta.
# BASE_URL="https://esempio.it"

# SMTP per l'invio delle email (se non configurato, il link di gestione viene solo loggato in console)
# SMTP_HOST="smtp.esempio.it"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Serate <noreply@esempio.it>"

# Nome del sito mostrato nell'interfaccia
# NEXT_PUBLIC_SITE_NAME="CAP Faenza"
